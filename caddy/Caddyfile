# DRS Unterrichtsmaterial — Reverse Proxy
# Default: HTTP-only auf Port 80 (Schul-LAN intern).
# Für HTTPS mit self-signed Cert: siehe Block unten (auskommentieren + Domain setzen).

:80 {
    encode zstd gzip
    request_body {
        max_size 500MB   # erlaubt große Material-Uploads in den SMB-Share
    }

    # OnlyOffice Document Server (in eigenem LXC, IP via Env-Var)
    # Wenn /etc/caddy/onlyoffice.env existiert, wird die Variable {$ONLYOFFICE_HOST}
    # gesetzt und der Reverse-Proxy ist aktiv. Bei leerem Wert greift der Block nicht.
    @onlyoffice path /onlyoffice/*
    handle @onlyoffice {
        uri strip_prefix /onlyoffice
        reverse_proxy {$ONLYOFFICE_HOST:127.0.0.1:9981} {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    reverse_proxy 127.0.0.1:8000

    log {
        output file /var/log/caddy/drs.log {
            roll_size 10MB
            roll_keep 5
        }
        format console
    }
}

# Optional: HTTPS mit self-signed Cert.
# {
#     auto_https off
# }
# https://drs.lokal {
#     tls internal
#     reverse_proxy 127.0.0.1:8000
# }
